{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "write": "allow",
    "read": "allow",
    "list": "allow",
    "task": "allow",
    "external_directory": "allow",
    "grep": "allow",
    "glob": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "doom_loop": "allow",
    "question": "allow"
  },
  "provider": {
    "ollama": {
      "models": {
        "glm-5.1:cloud": {
          "name": "glm-5.1:cloud"
        },
        "glm-5:cloud": {
          "limit": {
            "context": 202752,
            "output": 131072
          },
          "name": "glm-5:cloud"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "shell": "tmux",
  "disabled_providers": [
    "ollama"
  ]
}